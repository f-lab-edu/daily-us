<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jaeychoi.dailyus.group.mapper.GroupMapper">

  <resultMap id="groupResultMap" type="com.jaeychoi.dailyus.group.domain.Group">
    <id property="groupId" column="group_id"/>
    <result property="name" column="name"/>
    <result property="intro" column="intro"/>
    <result property="groupImage" column="group_image"/>
    <result property="ownerId" column="owner_id"/>
    <result property="memberCount" column="member_count"/>
    <result property="createdAt" column="created_at"/>
    <result property="updatedAt" column="updated_at"/>
    <result property="deletedAt" column="deleted_at"/>
  </resultMap>

  <insert id="insert"
    parameterType="com.jaeychoi.dailyus.group.domain.Group"
    useGeneratedKeys="true"
    keyProperty="groupId">
    INSERT INTO user_groups (name,
                             intro,
                             group_image,
                             owner_id,
                             deleted_at)
    VALUES (#{name},
            #{intro},
            #{groupImage},
            #{ownerId},
            #{deletedAt})
  </insert>

  <insert id="insertMember">
    INSERT INTO group_members (group_id,
                               user_id)
    VALUES (#{groupId},
            #{userId})
  </insert>

  <update id="increaseMemberCount" parameterType="long">
    UPDATE user_groups
    SET member_count = member_count + 1
    WHERE group_id = #{groupId}
      AND deleted_at IS NULL
  </update>

  <select id="findActiveById"
    parameterType="long"
    resultMap="groupResultMap"
  >
    SELECT group_id,
           name,
           intro,
           group_image,
           owner_id,
           member_count,
           created_at,
           updated_at,
           deleted_at
    FROM user_groups
    WHERE group_id = #{groupId}
      AND deleted_at IS NULL
  </select>

  <select id="existsMemberByIdAndMemberId" resultType="boolean">
    SELECT EXISTS (SELECT 1
                   FROM group_members
                   WHERE group_id = #{groupId}
                     AND user_id = #{userId})
  </select>

  <select id="countJoinedGroupsByMemberId" parameterType="long" resultType="int">
    SELECT COUNT(*)
    FROM group_members
    WHERE user_id = #{userId}
  </select>

  <update id="increaseMemberCount" parameterType="long">
    UPDATE user_groups
    SET member_count = member_count + 1
    WHERE group_id = #{groupId}
      AND deleted_at IS NULL
  </update>

</mapper>
